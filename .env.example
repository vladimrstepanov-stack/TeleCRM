# Список Telegram ID через запятую. Бот не вызывает AI для остальных пользователей.
ALLOWED_TELEGRAM_IDS=123456789
TELEGRAM_BOT_TOKEN=replace_me

# Локально используйте свою доступную MySQL. Адрес 10.16.0.2 может быть внутренним для Beget.
DATABASE_URL=mysql+aiomysql://telecrm:change_me@127.0.0.1:3306/telecrm?charset=utf8mb4

AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1
AITUNNEL_API_KEY=replace_me
STT_MODEL=qwen3-asr-flash-2026-02-10
DEEPSEEK_MODEL=deepseek-chat
LOG_LEVEL=INFO
